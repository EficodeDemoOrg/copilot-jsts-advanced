# OpenWeatherMap API key (required for real API calls; leave empty for tests)
OPENWEATHERMAP_API_KEY=your_api_key_here

# OpenWeatherMap One Call API 3.0 base URL
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/3.0

# Application settings
APP_NAME=Weather App
APP_PORT=3000
DEBUG=false

# Alert thresholds (reserved for future custom alert profiles)
ALERT_WIND_SPEED_THRESHOLD=20.0
ALERT_TEMP_HIGH_THRESHOLD=40.0
ALERT_TEMP_LOW_THRESHOLD=-20.0
ALERT_HUMIDITY_THRESHOLD=90.0
